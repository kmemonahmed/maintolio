# Copy this file to .env for local development.
# These values are Docker-friendly defaults only. Do not commit real secrets.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Django database configuration. Inside Docker, DB_HOST should be "db".
DB_ENGINE=django.db.backends.postgresql
DB_NAME=maintolio
DB_USER=maintolio
DB_PASSWORD=maintolio
DB_HOST=db
DB_PORT=5432

# Celery, Redis, and cache configuration for docker-compose services.
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
